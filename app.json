{
  "expo": {
    "name": "BatchCam",
    "slug": "batchcam",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "batchcam",
    "splash": { "backgroundColor": "#000000" },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "BatchCam needs camera access to take photos in batches."
      }
    },
    "android": {
      "permissions": ["android.permission.CAMERA"]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "BatchCam needs camera access to take photos in batches."
        }
      ]
    ]
  }
}
